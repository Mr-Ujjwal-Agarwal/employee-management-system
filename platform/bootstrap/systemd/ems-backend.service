[Unit]
Description=Employee Management System Backend
After=network.target

[Service]
User=ubuntu
Group=ubuntu

WorkingDirectory=/home/ubuntu/employee-management-system/app/backend

Environment="PATH=/home/ubuntu/employee-management-system/app/backend/venv/bin"

ExecStart=/home/ubuntu/employee-management-system/app/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
